{
  "lazyCodeLoading": "requiredComponents",
  "globalStyle": {
    "navigationStyle": "default",
    "navigationBarTitleText": "小智",
    "navigationBarBackgroundColor": "#f8f8f8",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#FFFFFF"
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^fg-(.*)": "@/components/fg-$1/fg-$1.vue",
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue",
      "^(?!z-paging-refresh|z-paging-load-more)z-paging(.*)": "z-paging/components/z-paging$1/z-paging$1.vue"
    }
  },
  "tabBar": {
    "custom": false,
    "color": "#e6e6e6",
    "selectedColor": "#667dea",
    "backgroundColor": "#fff",
    "borderStyle": "black",
    "height": "50px",
    "fontSize": "10px",
    "iconWidth": "24px",
    "spacing": "3px",
    "list": [
      {
        "iconPath": "static/tabbar/robot.png",
        "selectedIconPath": "static/tabbar/robot_activate.png",
        "pagePath": "pages/index/index",
        "text": "首页",
        "icon": "home",
        "iconType": "uiLib"
      },
      {
        "iconPath": "static/tabbar/device.png",
        "selectedIconPath": "static/tabbar/device_activate.png",
        "pagePath": "pages/director-desk/index",
        "text": "导播",
        "icon": "i-carbon-video",
        "iconType": "uiLib"
      },
      {
        "iconPath": "static/tabbar/microphone.png",
        "selectedIconPath": "static/tabbar/microphone_activate.png",
        "pagePath": "pages/voice-clone/index",
        "text": "音色",
        "icon": "i-carbon-microphone",
        "iconType": "uiLib"
      },
      {
        "iconPath": "static/tabbar/system.png",
        "selectedIconPath": "static/tabbar/system_activate.png",
        "pagePath": "pages/settings/index",
        "text": "系统",
        "icon": "i-carbon-settings",
        "iconType": "uiLib"
      }
    ]
  },
  "pages": [
    {
      "path": "pages/index/index",
      "type": "home",
      "layout": "tabbar",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "首页"
      }
    },
    {
      "path": "pages/device-config/index",
      "type": "page",
      "style": {
        "navigationBarTitleText": "设备配置",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/director-desk/index",
      "type": "page",
      "layout": "tabbar",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "导播"
      }
    },
    {
      "path": "pages/settings/index",
      "type": "page",
      "layout": "default",
      "style": {
        "navigationBarTitleText": "设置",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/voice-clone/index",
      "type": "page",
      "layout": "tabbar",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "音色克隆"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-sub",
      "pages": [
        {
          "path": "agent/index",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationBarTitleText": "智能体",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "agent/provider",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationBarTitleText": "编辑源",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "agent/speedPitch",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationBarTitleText": "语音设置",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "agent/tools",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationBarTitleText": "编辑功能",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "chat-history/detail",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "聊天详情"
          }
        },
        {
          "path": "demo/index",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationBarTitleText": "分包页面"
          }
        },
        {
          "path": "forgot-password/index",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "ForgotPassword"
          }
        },
        {
          "path": "login/index",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "Login"
          }
        },
        {
          "path": "login/privacy-policy-en",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "Privacy Policy"
          }
        },
        {
          "path": "login/privacy-policy-zh",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "隐私政策"
          }
        },
        {
          "path": "login/user-agreement-en",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "User Agreement"
          }
        },
        {
          "path": "login/user-agreement-zh",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "用户协议"
          }
        },
        {
          "path": "register/index",
          "type": "page",
          "layout": "default",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "注册"
          }
        }
      ]
    }
  ]
}
